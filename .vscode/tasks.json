{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: Build Project",
            "type": "shell",
            "command": "cl",
            "args": [
                "/EHsc",
                "main.cpp",
                "lexer.cpp",
                "token.cpp",
                "parser.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\files"
            },
            "problemMatcher": ["$msCompile"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}